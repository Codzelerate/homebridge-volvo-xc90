  "description": "Homebridge plugin for Volvo XC90 2016 (Sensus) via Volvo Connected Vehicle API v2",
  "author": "Codzelerate <contact@codzelerate.com>",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
